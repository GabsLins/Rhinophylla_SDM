calc_area_km2 <- function(sf_obj) {
  sf_obj %>%
    st_make_valid() %>%
    st_transform(3857) %>%
    st_area() %>%
    sum() %>%
    as.numeric() / 1e6
}

area_iucn_km2     <- calc_area_km2(iucn_vampyrum)
area_mdd_km2      <- calc_area_km2(mdd_vampyrum)
area_binary_km2   <- calc_area_km2(binary_area_land)
area_concave_km2  <- calc_area_km2(occ_area_land)

areas_df <- data.frame(
  Map = c("IUCN", "MDD", "Threshold_binary", "Concave_polygon"),
  Area_km2 = c(area_iucn_km2, area_mdd_km2, area_binary_km2, area_concave_km2)
)

cat("\n================ AREA SUMMARY (km²) ================\n")
print(areas_df)
cat("====================================================\n\n")

write.csv(
  areas_df,
  file.path(output_dir_compare, "areas_comparison_km2.csv"),
  row.names = FALSE
)

