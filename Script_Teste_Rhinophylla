save_plot_png_tif <- function(p, filename_base, w = 12, h = 8, dpi = 300) {

  ggsave(
    filename = file.path(parts_dir, paste0(filename_base, ".png")),
    plot = p,
    width = w, height = h, units = "in",
    dpi = dpi, limitsize = FALSE
