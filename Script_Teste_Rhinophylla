  st_set_crs(4326) %>%
  st_crop(bbox_amer)

land_amer <- countries_amer %>%
  st_make_valid() %>%
  st_union() %>%
  st_as_sf() %>%
  st_make_valid()

# -----------------------------
occ_df <- coords %>%
  dplyr::rename(lon = x, lat = y)

occ_sf <- st_as_sf(occ_df, coords = c("lon", "lat"), crs = 4326) %>%
  st_crop(bbox_amer)

cat("Occurrences loaded:", nrow(occ_sf), "\n")

if (nrow(occ_sf) < 3) {
  stop("Need at least 3 occurrence points to build a concave hull.")
}

# -----------------------------
occ_metric  <- st_transform(occ_sf, 3857)
land_metric <- st_transform(land_amer, 3857)

occ_concave_m <- concaveman::concaveman(
  occ_metric,
  concavity = 2,
  length_threshold = 20000
)

occ_area_m <- st_buffer(st_make_valid(occ_concave_m), dist = 5000) %>%
  st_make_valid()

occ_area_land_m <- st_intersection(occ_area_m, land_metric) %>%
  st_make_valid()

occ_area_land <- st_transform(occ_area_land_m, 4326)


# -----------------------------
binary_rast <- binary_raster

binary_rast_crop <- tryCatch(
  terra::crop(binary_rast, terra::ext(-170, -30, -60, 80)),
  error = function(e) binary_rast
)

binary_rast_crop[is.na(binary_rast_crop)] <- 0

agg_fact  <- 6
min_cells <- 8

cat("Aggregating binary raster with factor =", agg_fact, "\n")

binary_rast_small <- terra::aggregate(
  binary_rast_crop,
  fact = agg_fact,
  fun = max,
  na.rm = TRUE
)

binary_rast_small[is.na(binary_rast_small)] <- 0

binary_rast_small_trim <- binary_rast_small
binary_rast_small_trim[binary_rast_small_trim == 0] <- NA
binary_rast_small_trim <- terra::trim(binary_rast_small_trim)

binary_rast_small <- binary_rast_small_trim
binary_rast_small[is.na(binary_rast_small)] <- 0

patch <- terra::patches(binary_rast_small, directions = 8)
freq_patch <- as.data.frame(terra::freq(patch))
freq_patch <- freq_patch[!is.na(freq_patch$value), ]

keep_ids <- freq_patch$value[freq_patch$count >= min_cells]

binary_rast_clean <- binary_rast_small
binary_rast_clean[!(patch %in% keep_ids)] <- 0

binary_rast_clean_trim <- binary_rast_clean
binary_rast_clean_trim[binary_rast_clean_trim == 0] <- NA
binary_rast_clean_trim <- terra::trim(binary_rast_clean_trim)

binary_rast_clean <- binary_rast_clean_trim
binary_rast_clean[is.na(binary_rast_clean)] <- 0

cat("Converting cleaned binary raster to polygons...\n")

binary_poly <- terra::as.polygons(
  binary_rast_clean,
  dissolve = TRUE,
  values = TRUE,
  na.rm = TRUE
)

binary_poly_sf <- sf::st_as_sf(binary_poly) %>%
  st_set_crs(4326) %>%
  st_make_valid()

geom_col <- attr(binary_poly_sf, "sf_column")
val_cols <- setdiff(names(binary_poly_sf), geom_col)
val_col  <- val_cols[1]

binary_poly_sf <- binary_poly_sf %>%
  dplyr::filter(.data[[val_col]] == 1)

binary_metric <- st_transform(binary_poly_sf, 3857)

binary_area_land_m <- st_intersection(binary_metric, land_metric) %>%
  st_make_valid()

binary_area_land <- st_transform(binary_area_land_m, 4326)

if (nrow(binary_area_land) == 0) {
  stop("Binary suitability polygon became empty after land clipping.")
}

