extract_prediction_vector <- function(pred, expected_n) {
  
  if (is.null(pred)) {
    return(NULL)
  }
  
  if (is.numeric(pred) && length(pred) == expected_n) {
    return(as.numeric(pred))
  }
  
  if (is.matrix(pred) || is.data.frame(pred)) {
    
    pred_df <- as.data.frame(pred)
    
    if (nrow(pred_df) == expected_n) {
      
      num_cols <- which(sapply(pred_df, is.numeric))
      
      if (length(num_cols) > 0) {
        return(as.numeric(pred_df[[num_cols[1]]]))
      }
    }
  }
  
  if (is.list(pred)) {
    
    for (i in seq_along(pred)) {
      
      out <- tryCatch(
        extract_prediction_vector(pred[[i]], expected_n),
        error = function(e) NULL
      )
      
      if (!is.null(out) && length(out) == expected_n) {
        return(out)
      }
    }
  }
  
  pred_df_try <- tryCatch(
    as.data.frame(pred),
    error = function(e) NULL
  )
  
  if (!is.null(pred_df_try) && nrow(pred_df_try) == expected_n) {
    
    num_cols <- which(sapply(pred_df_try, is.numeric))
    
    if (length(num_cols) > 0) {
      return(as.numeric(pred_df_try[[num_cols[1]]]))
    }
  }
  
  return(NULL)
}

predict_values_for_chunk <- function(mod_obj, newdata_chunk, model_name) {
  
  pred <- tryCatch(
    withCallingHandlers(
      predict(
        mod_obj,
        newdata = newdata_chunk
      ),
      warning = function(w) {
        message("Aviso em ", model_name, ": ", conditionMessage(w))
        invokeRestart("muffleWarning")
      }
    ),
    error = function(e) {
      message("Tentativa com newdata falhou em ", model_name, ": ", e$message)
      NULL
    }
  )
  
  if (is.null(pred)) {
    
    pred <- tryCatch(
      withCallingHandlers(
        predict(
          mod_obj,
          newdata_chunk
        ),
        warning = function(w) {
          message("Aviso em ", model_name, ": ", conditionMessage(w))
          invokeRestart("muffleWarning")
        }
      ),
      error = function(e) {
        message("Tentativa posicional falhou em ", model_name, ": ", e$message)
        NULL
      }
    )
  }
  
  pred_vec <- extract_prediction_vector(
    pred,
    expected_n = nrow(newdata_chunk)
  )
  
  if (is.null(pred_vec) || length(pred_vec) != nrow(newdata_chunk)) {
    return(NULL)
  }
  
  pred_vec <- as.numeric(pred_vec)
  pred_vec[!is.finite(pred_vec)] <- NA_real_
  
  return(pred_vec)
}

predict_model_to_raster_by_blocks <- function(mod_obj, new_env, model_name, chunk_size = 100000) {
  
  cat("Extraindo valores ambientais para projeção...\n")
  
  env_vals <- terra::values(new_env, mat = TRUE)
  colnames(env_vals) <- names(new_env)
  
  complete_idx <- which(stats::complete.cases(env_vals))
  
  if (length(complete_idx) == 0) {
    message("Nenhuma célula ambiental completa para projetar ", model_name)
    return(NULL)
  }
  
  cat("Células completas para projeção:", length(complete_idx), "\n")
  
  result_vals <- rep(NA_real_, terra::ncell(new_env))
  
  starts <- seq(1, length(complete_idx), by = chunk_size)
  
  for (s in starts) {
    
    e <- min(s + chunk_size - 1, length(complete_idx))
    idx <- complete_idx[s:e]
    
    newdata_chunk <- as.data.frame(env_vals[idx, , drop = FALSE])
    names(newdata_chunk) <- names(new_env)
    
    pred_chunk <- predict_values_for_chunk(
      mod_obj = mod_obj,
      newdata_chunk = newdata_chunk,
      model_name = model_name
    )
    
    if (is.null(pred_chunk)) {
      message(
        "Falha na predição do bloco ",
        s,
        "-",
        e,
        " para ",
        model_name
      )
      next
    }
    
    result_vals[idx] <- pred_chunk
    
    cat("Bloco projetado:", s, "-", e, "\n")
  }
  
  if (sum(is.finite(result_vals)) == 0) {
    message("Modelo ", model_name, " não produziu nenhum valor finito.")
    return(NULL)
  }
  
  pred_r <- new_env[[1]]
  terra::values(pred_r) <- result_vals
  
  pred_r <- terra::ifel(pred_r < 0, 0, pred_r)
  
  return(pred_r)
}

predict_one_biomod_model <- function(model_name, bm_out, new_env, out_dir) {
  
  cat("\nProjetando modelo:", model_name, "\n")
  
  fun_env <- environment()
  
  loaded_names <- tryCatch(
    BIOMOD_LoadModels(
      bm.out = bm_out,
      full.name = model_name
    ),
    error = function(e) {
      message("Falha ao carregar modelo ", model_name, ": ", e$message)
      NULL
    }
  )
  
  if (is.null(loaded_names) || length(loaded_names) == 0) {
    return(NA_character_)
  }
  
  loaded_names <- as.character(loaded_names)
  
  cat("Nome retornado por BIOMOD_LoadModels:", paste(loaded_names, collapse = ", "), "\n")
  
  model_object_name <- loaded_names[1]
  
  if (!exists(model_object_name, envir = fun_env, inherits = TRUE)) {
    
    if (exists(model_object_name, envir = .GlobalEnv, inherits = FALSE)) {
      mod_obj <- get(model_object_name, envir = .GlobalEnv)
    } else {
      message("Falha ao obter objeto carregado para ", model_name, ".")
      return(NA_character_)
    }
    
  } else {
    
    mod_obj <- get(model_object_name, envir = fun_env, inherits = TRUE)
  }
  
  out_file <- file.path(
    out_dir,
    paste0(safe_filename(model_name), ".tif")
  )
  
  dir.create(dirname(out_file), recursive = TRUE, showWarnings = FALSE)
  
  pred_r <- predict_model_to_raster_by_blocks(
    mod_obj = mod_obj,
    new_env = new_env,
    model_name = model_name,
    chunk_size = projection_chunk_size
  )
  
  if (is.null(pred_r) || !terra::hasValues(pred_r)) {
    message("Modelo ", model_name, " não gerou raster válido.")
    return(NA_character_)
  }
  
  terra::writeRaster(
    pred_r,
    out_file,
    overwrite = TRUE,
    datatype = "FLT4S"
  )
  
  if (!file.exists(out_file)) {
    message("Arquivo não encontrado após escrita: ", out_file)
    return(NA_character_)
  }
  
  cat("Predição salva em:", out_file, "\n")
  
  if (exists(model_object_name, envir = fun_env, inherits = FALSE)) {
    rm(list = model_object_name, envir = fun_env)
  }
  
  return(out_file)
}

