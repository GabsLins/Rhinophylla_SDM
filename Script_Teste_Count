format_metric_label <- function(x, digits = 3) {
  
  out <- ifelse(
    !is.finite(x),
    "NA",
    ifelse(
      abs(x) >= 10000 | abs(x) < 0.001,
      formatC(x, format = "e", digits = 2),
      formatC(x, format = "f", digits = digits)
    )
  )
  
  return(out)
}

