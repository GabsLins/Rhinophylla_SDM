make_var_panel <- function(r, varname, coords_obj, imp_df) {
  
  rr <- terra::rast(r)
  
  crs_r <- terra::crs(rr)
  
  if (is.na(crs_r) || crs_r == "") {
    crs_r <- "EPSG:4326"
  }
  
  coords_xy <- as_xy_df(coords_obj)
  coords_xy$count <- coords_obj$count
  
  coords_v <- as_points_vect(coords_xy[, c("x", "y")], crs_r)
  
  imp_val <- imp_df %>%
    dplyr::filter(var == varname) %>%
    dplyr::pull(importance)
  
  imp_txt <- ifelse(
    length(imp_val) > 0,
    sprintf(" | Imp: %.3f", imp_val[1]),
    " | Imp: NA"
  )
  
  r_df <- rast_to_plot_df(rr)
  
  scale_info <- get_map_limits(varname, r_df$val)
  
  map <- ggplot() +
    geom_tile(
      data = r_df,
      aes(x = x, y = y, fill = val)
    ) +
    geom_point(
      data = coords_xy,
      aes(x = x, y = y, size = count),
      color = "red",
      alpha = 0.65
    ) +
    scale_size_area(max_size = 3) +
    scale_fill_viridis_c(
      option = "viridis",
      name = varname,
      limits = scale_info$limits,
      oob = scales::squish
    ) +
    guides(size = "none") +
    coord_sf(expand = FALSE) +
    theme_minimal() +
    labs(
      title = paste0(varname, imp_txt),
      subtitle = scale_info$label
    ) +
    theme(
      plot.title = element_text(face = "bold"),
      plot.subtitle = element_text(size = 8)
    )
  
  obs_vals <- terra::extract(rr, coords_v)[, 2]
  
  df <- data.frame(
    Value = obs_vals,
    Count = coords_obj$count,
    log_count = log1p(coords_obj$count)
  ) %>%
    dplyr::filter(
      is.finite(Value),
      !is.na(Value),
      is.finite(Count),
      Count > 0
    )
  
  rel_plot <- ggplot(df, aes(x = Value, y = log_count)) +
    geom_point(
      aes(size = Count),
      alpha = 0.55,
      color = "darkred"
    ) +
    geom_smooth(
      method = "lm",
      se = FALSE,
      linewidth = 0.7,
      color = "black"
    ) +
    scale_size_area(max_size = 3) +
    guides(size = "none") +
    theme_minimal() +
    labs(
      title = paste("Count relationship –", varname),
      x = varname,
      y = "log1p(count)"
    )
  
  map | rel_plot
}

