  lon = coords$x,
  lat = coords$y,
  count = coords$count
)

target_ext <- terra::ext(-120, -30, -60, 30)

pred_crop <- tryCatch(
  terra::crop(predicted_count_raster, target_ext),
  error = function(e) NULL
)

use_pred <- pred_crop

if (is.null(use_pred) || !terra::hasValues(use_pred)) {
  use_pred <- predicted_count_raster
}

pred_df <- as.data.frame(use_pred, xy = TRUE, na.rm = TRUE)
colnames(pred_df)[3] <- "Predicted_Count"

if (!is.null(pred_crop) && terra::hasValues(pred_crop)) {
  xlim_use <- c(-120, -30)
  ylim_use <- c(-60, 30)
} else {
  e <- terra::ext(use_pred)
  xlim_use <- c(e$xmin, e$xmax)
  ylim_use <- c(e$ymin, e$ymax)
}

pred_scale_info <- get_prediction_limits(pred_df$Predicted_Count)

predicted_count_map <- ggplot() +
  geom_tile(
    data = pred_df,
    aes(x = x, y = y, fill = Predicted_Count)
  ) +
  geom_sf(
    data = countries,
    fill = NA,
    color = "black",
    linewidth = 0.2
  ) +
  geom_point(
    data = pres_coords,
    aes(x = lon, y = lat, size = count),
    color = "black",
    alpha = 0.6
  ) +
  scale_size_continuous(
    name = "Observed count",
    range = c(0.6, 3.5),
    trans = "sqrt"
  ) +
  scale_fill_viridis_c(
    option = "plasma",
    name = "Predicted count",
    limits = pred_scale_info$limits,
    oob = scales::squish
  ) +
  coord_sf(
    xlim = xlim_use,
    ylim = ylim_use,
    expand = FALSE
  ) +
  theme_minimal() +
  labs(
    title = "Predicted Count Map – Ensemble",
    subtitle = pred_scale_info$label
  ) +
  theme(
    plot.title = element_text(face = "bold", hjust = 0.5),
    plot.subtitle = element_text(size = 9, hjust = 0.5)
  )

print(predicted_count_map)


