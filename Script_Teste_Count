rast_to_plot_df <- function(r, ext = target_ext, max_cells = max_cells_plot) {
  
  rr <- terra::rast(r)
  
  rr_crop <- tryCatch(
    terra::crop(rr, ext),
    error = function(e) NULL
  )
  
  rr_use <- rr_crop
  
  if (is.null(rr_use) || !terra::hasValues(rr_use)) {
    rr_use <- rr
  }
  
  if (terra::ncell(rr_use) > max_cells) {
    
    fact <- ceiling(sqrt(terra::ncell(rr_use) / max_cells))
    
    rr_use <- terra::aggregate(
      rr_use,
      fact = fact,
      fun = mean,
      na.rm = TRUE
    )
  }
  
  df <- as.data.frame(rr_use, xy = TRUE, na.rm = TRUE)
  colnames(df)[3] <- "val"
  
  return(df)
}


