# Para RMSE e MAE, usamos escala pseudo-log10 para impedir que valores extremos
# achatem visualmente os demais modelos. Para Rsquared, mantemos escala linear.

plot_metric_count <- function(metric) {
  
  df_metric <- df_models %>%
    dplyr::filter(Metrica == metric) %>%
    dplyr::mutate(Modelo = factor(Modelo, levels = models_to_run))
  
  summary_metric <- metric_summary %>%
    dplyr::filter(Metrica == metric) %>%
    dplyr::mutate(Modelo = factor(Modelo, levels = models_to_run))
  
  if (nrow(df_metric) == 0) {
    return(
      ggplot() +
        theme_void() +
        labs(title = paste(metric, "- no data"))
    )
  }
  
  y_lab <- metric
  subtitle_txt <- ifelse(
    metric %in% c("RMSE", "MAE"),
    "Lower values indicate better performance | pseudo-log10 scale",
    "Higher values indicate better performance"
  )
  
  p <- ggplot(
    df_metric,
    aes(x = Modelo, y = Valor)
  ) +
    geom_boxplot(
      width = 0.45,
      outlier.shape = NA,
      fill = "gray92",
      color = "gray30"
    ) +
    geom_jitter(
      width = 0.08,
      alpha = 0.65,
      size = 1.8,
      color = "gray20"
    ) +
    geom_point(
      data = summary_metric,
      aes(x = Modelo, y = median),
      inherit.aes = FALSE,
      shape = 23,
      size = 3.2,
      fill = "white",
      color = "black"
    ) +
    geom_text(
      data = summary_metric,
      aes(
        x = Modelo,
        y = median,
        label = paste0("med=", median_label)
      ),
      inherit.aes = FALSE,
      vjust = -0.9,
      size = 3.0
    ) +
    theme_minimal() +
    labs(
      title = metric,
      subtitle = subtitle_txt,
      x = "Algorithm",
      y = y_lab
    ) +
    theme(
      plot.title = element_text(size = 15, face = "bold", hjust = 0.5),
      plot.subtitle = element_text(size = 8, hjust = 0.5),
      axis.title = element_text(size = 11),
      axis.text = element_text(size = 10)
    )
  
  if (metric %in% c("RMSE", "MAE")) {
    p <- p +
      scale_y_continuous(
        trans = scales::pseudo_log_trans(base = 10),
        labels = scales::label_scientific(digits = 2)
      )
  } else {
    p <- p +
      scale_y_continuous(
        labels = scales::label_number(accuracy = 0.001)
      )
  }
  
  return(p)
}

