plot_metric_count <- function(metric, ens_val = NA_real_) {
  
  df_metric <- df_models %>%
    dplyr::filter(Metrica == metric)
  
  p <- ggplot(
    df_metric,
    aes(Modelo, Valor)
  ) +
    geom_boxplot(width = 0.45, outlier.size = 1) +
    geom_jitter(width = 0.08, alpha = 0.5, size = 1.5) +
    theme_minimal() +
    labs(
      title = metric,
      x = "Modelo",
      y = metric
    ) +
    theme(
      plot.title = element_text(size = 18, face = "bold"),
      axis.title = element_text(size = 14),
      axis.text = element_text(size = 12)
    )
  
  if (is.finite(ens_val)) {
    
    p <- p +
      geom_hline(
        yintercept = ens_val,
        color = "blue",
        linewidth = 1
      ) +
      annotate(
        "text",
        x = Inf,
        y = ens_val,
        label = sprintf("Ensemble = %.3f", ens_val),
        hjust = 1.05,
        vjust = -0.4,
        color = "blue",
        size = 3.2
      )
  }
  
  return(p)
}

