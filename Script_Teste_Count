fix_num <- function(v) {
  v <- trimws(as.character(v))
  v <- gsub(",", ".", v)
  v <- gsub("[^0-9\\.-]", "", v)
  
  v <- sapply(v, function(s) {
    if (is.na(s) || s == "") return(NA_character_)
    
    partes <- strsplit(s, "\\.")[[1]]
    
    # Corrige casos como -16.783.333 -> -16.783333
    if (length(partes) > 2) {
      s <- paste0(partes[1], ".", paste(partes[-1], collapse = ""))
    }
    
    return(s)
  })
  
  as.numeric(v)
}

