prep_layer <- function(path, ref = NULL, method = "bilinear") {
  
  if (!file.exists(path)) {
    stop("Arquivo não encontrado: ", path)
  }
  
  r <- raster::raster(path)
  r <- raster::crop(r, ext_america)
  
  if (!is.null(ref)) {
    r <- raster::resample(r, ref, method = method)
  }
  
  return(r)
}

